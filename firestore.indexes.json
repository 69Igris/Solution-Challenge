{
  "indexes": [
    {
      "_comment": "Coordinator dashboard active queue — sort by severity, then recency",
      "collectionGroup": "sos_alerts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "parsed.severityScore", "order": "DESCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Volunteer radius query — geohash range + status + recency",
      "collectionGroup": "sos_alerts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "geohash", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Citizen SOS history",
      "collectionGroup": "sos_alerts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "citizenUid", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Volunteer's active mission lookup",
      "collectionGroup": "sos_alerts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "matchedVolunteerUid", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "Available volunteers by role + availability",
      "collectionGroup": "users",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "role", "order": "ASCENDING" },
        { "fieldPath": "volunteer.isAvailable", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
