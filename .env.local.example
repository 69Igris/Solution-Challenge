# ---------------------------------------------------------------
# SANKALP — Environment Variables (copy to .env.local and fill in)
# ---------------------------------------------------------------

# === Firebase Web SDK (client-side) ===
# From Firebase Console → Project Settings → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === Firebase Admin SDK (server-side) ===
# Service account JSON, base64-encoded. Generate with:
#   cat service-account.json | base64 | tr -d '\n'
# Leave blank on Cloud Run / Cloud Functions to use Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Storage bucket — usually `<project-id>.appspot.com` (legacy) or
# `<project-id>.firebasestorage.app` (new projects post-Oct 2024). If unset,
# falls back to NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET.
FIREBASE_STORAGE_BUCKET=

# Storage disable flag — set to 1 to skip media upload entirely. Use this when
# you're on the free Spark plan and don't want to enable Blaze billing.
# The Gemini parse still receives photo + voice inline as base64, so AI quality
# is unchanged — only the post-parse media persistence is dropped (volunteers
# and coordinators see the AI summary instead of the raw media).
STORAGE_DISABLED=0

# === Mapbox (client-side) ===
NEXT_PUBLIC_MAPBOX_TOKEN=

# === Google Gen AI / Vertex AI (server-side) ===
# Path A — Public Gen AI API (fastest to set up, good for hackathon):
GEMINI_API_KEY=
# Default model. `gemini-2.5-flash` is fastest + cheapest with the widest
# free-tier availability. Use `gemini-2.5-pro` for higher accuracy at the cost
# of latency.
GEMINI_MODEL=gemini-2.5-flash

# Mock fallback — when 1, the API route returns a deterministic keyword-based
# parse without calling Gemini. Use when quota is unavailable, conference WiFi
# is broken, or for cheap deterministic tests. Set to 0 in production.
MOCK_GEMINI=0

# Path B — Vertex AI (production / when team has GCP billing):
# Set VERTEX_AI=1 to route Gemini calls through Vertex in asia-south1.
VERTEX_AI=0
GOOGLE_CLOUD_PROJECT=sankalp-prod
GOOGLE_CLOUD_LOCATION=asia-south1

# === Demo mode ===
# When 1, /api/sos accepts an `x-demo-uid` header instead of a Firebase ID token.
# NEVER enable this in production.
SANKALP_DEMO_MODE=0
